PEAKURL_ENV="development"
PEAKURL_DEBUG=true
SITE_URL="https://peakurl.dev"
PEAKURL_AUTH_KEY=""
PEAKURL_AUTH_SALT=""
PEAKURL_CONTENT_DIR="content"
PEAKURL_GEOIP_DB_PATH="content/uploads/geoip/GeoLite2-City.mmdb"

DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_DATABASE="peakurl"
DB_USERNAME="root"
DB_PASSWORD=""
DB_CHARSET="utf8mb4"
DB_PREFIX="peakurl_"

SESSION_COOKIE_NAME="peakurl_session"
SESSION_LIFETIME="2592000"
SESSION_COOKIE_PATH="/"
SESSION_COOKIE_DOMAIN=""
SESSION_COOKIE_SAME_SITE="Strict"
SESSION_COOKIE_SECURE="auto"

PEAKURL_OWNER_FALLBACK="false"
PEAKURL_OWNER_FIRST_NAME="Workspace"
PEAKURL_OWNER_LAST_NAME="Owner"
PEAKURL_OWNER_USERNAME="admin"
PEAKURL_OWNER_EMAIL="owner@example.com"
PEAKURL_OWNER_PASSWORD="admin12345"
PEAKURL_WORKSPACE_NAME="Workspace"
PEAKURL_WORKSPACE_SLUG="workspace"
